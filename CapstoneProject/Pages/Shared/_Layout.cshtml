<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CapstoneProject</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CapstoneProject.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm custom-navbar border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">Guild Quest </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Profile">Profile</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/CharacterInput">Character</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Announcements">Announcements</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Community">Community</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Quest">Quests</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Friends">Friends</a>
                        </li>
                        <li class="nav-item">
                            @if(Context.Session.GetString("LoggedIn") != null){
                               <form method="post" asp-page="/Logout" asp-page-handler="Logout">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="nav-link" style="background: none; border: none;">Log Out</button>
                               </form>
                            }
                            else
                            {
                                <a class="nav-link" asp-area="" asp-page="/login">Log In</a>
                            }
                            
                        </li>

                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <footer class="border-top footer text-muted">
        <div class="container" style="display:flex; align-items:center; justify-content:space-between;">
            &copy; 2026 - CapstoneProject - <a asp-area="" asp-page="/Privacy">Privacy</a>
            @if (Context.Session.GetString("LoggedIn") == "true")
            {
                <button id="friendsTabBtn" class="chat-btn" onclick="toggleChat()" style="background:#DAA520; border:none; padding:6px 14px; border-radius:6px; cursor:pointer; font-weight:bold; width:auto;">
                    💬 Chat
                </button>
            }
        </div>
    </footer>

    <!-- Chat popup sits above footer -->
    @if (Context.Session.GetString("LoggedIn") == "true")
    {
        <div id="chat-widget">
            <div id="chat-body" style="display:none;">
                <div id="chatHome">
                    <button onclick="showFriends()">Friends</button>
                </div>
                <div id="friendsDM" style="display:none;">
                    <button onclick="goHome()">Back</button>
                    <div id="friendsContainer"></div>
                </div>
                <div id="conversationView" style="display:none;">
                    <button onclick="closeConversation()">Back</button>
                    <div id="chat-messages"></div>
                    <div id="inputBox" style="display:none;">
                        <input type="text"
                               id="chat-input"
                               placeholder="Type a message..." />
                        <button onclick="sendMessage(currentConversationId)">Send</button>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- The Chat Starts Here -->
    <div id="chat-widget" class="chat-closed">
        <div id="chat-body" style="display:none;">
            <div id="chatHome">
                <button id="friendsTabBtn" onclick="showFriends()">Friends</button>
            </div>
            <div id="friendsDM" style="display:none;">
                <button onclick="goHome()">Back</button>
                <div id="friendsContainer"></div>
            </div>
            <div id="conversationView" style="display:none;">
                <button onclick="closeConversation()">Back</button>
                <div id="chat-messages"></div>
                <div id="inputBox" style="display:none;">
                    <input type="text"
                           id="chat-input"
                           placeholder="Type a message..." />
                    <button onclick="sendMessage(currentConversationId)">Send</button>
                </div>
            </div>
        </div>
    </div>
    <!-- Toast container -->
    <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 9999; padding: 2px;">
        <div id="logoutToast" class="toast align-items-center text-bg-success border-0" style=" background-color: #585858;" role="alert">
            <div class="d-flex">
                <div class="toast-body">
                    You have been logged out successfully.
                </div>
           </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        const currentUser = "@Context.Session.GetString("Username")";
        const currentUserId = @Context.Session.GetInt32("UserID");
    </script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

    @if (TempData["ShowLogoutToast"] != null)
{
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var toast = new bootstrap.Toast(document.getElementById("logoutToast"), {
                autohide: true,
                delay: 2000
            });
            toast.show();
        });
    </script>
}
</body>
</html>
